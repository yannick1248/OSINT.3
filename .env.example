# API
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000

# Legal/audit defaults for local manual tests only; production callers must provide request-scoped values.
DEFAULT_LEGAL_BASIS=missing_person_investigation
DEFAULT_REQUESTOR_ID=local-operator

# External OSINT providers
HIBP_API_KEY=
INTELX_API_KEY=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
