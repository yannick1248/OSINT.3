EYEOFWEB_URL=http://eyeofweb:8080/search

# Datastores
POSTGRES_USER=osintomega
POSTGRES_PASSWORD=change-me
POSTGRES_DB=osintomega
DATABASE_URL=postgresql+psycopg://osintomega:change-me@postgres:5432/osintomega
REDIS_URL=redis://redis:6379/0
ELASTICSEARCH_URL=http://elasticsearch:9200
MILVUS_HOST=milvus
MILVUS_PORT=19530
